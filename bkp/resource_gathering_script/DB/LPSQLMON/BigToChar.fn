
CREATE FUNCTION [dbo].[BigToChar](@val Bigint)
RETURNS NVARCHAR(50)
AS 
BEGIN
    DECLARE @ret NVARCHAR(50);
	SELECT @ret = SUBSTRING(CONVERT(NVARCHAR(50), CONVERT(MONEY, ISNULL(@val,0)), 1), 1, CHARINDEX('.', CONVERT(NVARCHAR(50), CONVERT(MONEY, ISNULL(@val,0)), 1))-1)
    RETURN @ret;
END;


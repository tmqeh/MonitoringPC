{"annotations": {"list": [{"builtIn": 1, "datasource": {"type": "datasource", "uid": "grafana"}, "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "target": {"limit": 100, "matchAny": false, "tags": [], "type": "dashboard"}, "type": "dashboard"}]}, "description": "Visualize AWS RDS Resource Usage", "editable": true, "fiscalYearStartMonth": 0, "gnetId": 707, "graphTooltip": 0, "id": 28, "iteration": 1652337965120, "links": [], "liveNow": false, "panels": [{"aliasColors": {}, "bars": false, "dashLength": 10, "dashes": false, "datasource": {"type": "mssql", "uid": "55sV9KGMz"}, "editable": true, "error": false, "fieldConfig": {"defaults": {"links": []}, "overrides": [{"matcher": {"id": "byRegexp", "options": "/Usage/"}, "properties": [{"id": "displayName", "value": "${__field.labels.ServerHost}"}]}]}, "fill": 0, "fillGradient": 0, "grid": {}, "gridPos": {"h": 21, "w": 24, "x": 0, "y": 0}, "hiddenSeries": false, "id": 17, "isNew": true, "legend": {"alignAsTable": true, "avg": true, "current": false, "max": true, "min": true, "rightSide": true, "show": true, "sort": "current", "sortDesc": true, "total": false, "values": true}, "lines": true, "linewidth": 1, "links": [], "nullPointMode": "connected", "options": {"alertThreshold": true}, "percentage": false, "pluginVersion": "8.5.2", "pointradius": 1, "points": true, "renderer": "flot", "seriesOverrides": [], "spaceLength": 10, "stack": false, "steppedLine": false, "targets": [{"alias": "", "datasource": {"type": "mssql", "uid": "55sV9KGMz"}, "format": "time_series", "rawSql": "\r\nSELECT time, '[' + $Rsrc_Name + '] ' + ServerHost as ServerHost, \r\n       CASE WHEN $Rsrc_Name = 'CPUUtilization' THEN CPU_PCT\r\n            WHEN $Rsrc_Name = 'FreeStorageSpace' THEN Storage_Used_PCT\r\n            WHEN $Rsrc_Name = 'FreeableMemory' THEN MEM_Used_PCT\r\n            WHEN $Rsrc_Name = 'ReadIOPS' THEN Read_IOPS\r\n            WHEN $Rsrc_Name = 'WriteIOPS' THEN Write_IOPS\r\n            WHEN $Rsrc_Name = 'TotalIOPS' THEN Read_IOPS+Write_IOPS\r\n             END as Usage\r\nFROM (SELECT DATEADD(hh, -9, b.CollectDTM) as time, a.ServerHost\r\n           -- CPU\r\n           , ISNULL(MAX(case when Rsrc_Name = 'CPUUtilization' then Rsrc_Val end),0) CPU_PCT\r\n           -- Storage\r\n           , MIN(a.Storage_Size_GB) as Storage_TOT_GB\r\n           , MIN(CAST(ROUND(case when Rsrc_Name = 'FreeStorageSpace' then Rsrc_Val end /1024/1024/1024,0) as INT)) as Storage_Free_GB\r\n           , MIN(a.Storage_Size_GB) - MIN(CAST(ROUND(case when Rsrc_Name = 'FreeStorageSpace' then Rsrc_Val end/1024/1024/1024,0) as INT)) as Storage_Use_GB\r\n           , CAST((MIN(a.Storage_Size_GB) - MIN(ROUND(case when Rsrc_Name = 'FreeStorageSpace' then Rsrc_Val end/1024/1024/1024,0))) / MIN(a.Storage_Size_GB) * 100 as DECIMAL(10,2)) as Storage_Used_PCT\r\n           -- Memory\r\n           , MIN(c.Memory_GB) as MEM_TOT_GB\r\n           , MIN(CAST(ROUND(case when Rsrc_Name = 'FreeableMemory' then Rsrc_Val end/1024/1024/1024,0) as INT)) as MEM_Free_GB\r\n           , MIN(c.Memory_GB) - MIN(CAST(ROUND(case when Rsrc_Name = 'FreeableMemory' then Rsrc_Val end/1024/1024/1024,0) as INT)) as MEM_Use_GB\r\n           , CAST((MIN(c.Memory_GB) - MIN(ROUND(case when Rsrc_Name = 'FreeableMemory' then Rsrc_Val end/1024/1024/1024,0))) / MIN(c.Memory_GB) * 100 as DECIMAL(10,2)) as MEM_Used_PCT\r\n           -- IOPS\r\n           , MAX(case when Rsrc_Name = 'ReadIOPS' then Rsrc_Val end) as Read_IOPS\r\n           , MAX(case when Rsrc_Name = 'WriteIOPS' then Rsrc_Val end) as Write_IOPS\r\n           , MAX(case when Rsrc_Name = 'ReadIOPS' then Rsrc_Val end) + MAX(case when Rsrc_Name = 'WriteIOPS' then Rsrc_Val end) as TOT_IOPS\r\n        FROM [dbo].[TB_Rds_Comm_Info_M] a with (nolock), [dbo].[TB_Rds_Rsrc_L] b with (nolock), [dbo].[TB_Rds_Class_Info_M] c with (nolock)\r\n       WHERE 1=1\r\n         AND b.CollectDTM BETWEEN DATEADD(hh, 9, $__timeFrom()) AND DATEADD(hh, 9, $__timeTo()) \r\n         AND a.ServerHost  = b.ServerHost\r\n         AND a.ServerClass = c.ServerClass\r\n        -- AND b.CollectDT = CONVERT(VARCHAR, GETDATE(), 112)\r\n         AND a.ServerHost IN ($ServerHost)\r\n         AND a.VPC IN ($VPC)\r\n         AND b.Rsrc_Name IN ($Rsrc_Name)\r\n      GROUP BY b.CollectDTM, a.ServerHost\r\n     ) AS ZZ\r\nORDER BY time", "refId": "A"}], "thresholds": [], "timeRegions": [], "title": "[Choosable] Resource Usage", "tooltip": {"msResolution": false, "shared": true, "sort": 0, "value_type": "cumulative"}, "type": "graph", "xaxis": {"mode": "time", "show": true, "values": []}, "yaxes": [{"$$hashKey": "object:212", "format": "none", "logBase": 1, "show": true}, {"$$hashKey": "object:213", "format": "iops", "logBase": 1, "min": "0", "show": false}], "yaxis": {"align": false}}, {"aliasColors": {}, "bars": false, "dashLength": 10, "dashes": false, "datasource": {"type": "mssql", "uid": "55sV9KGMz"}, "editable": true, "error": false, "fieldConfig": {"defaults": {"links": []}, "overrides": [{"matcher": {"id": "byRegexp", "options": "/Rsrc_Val/"}, "properties": [{"id": "displayName", "value": "${__field.labels.ServerHost}"}]}]}, "fill": 0, "fillGradient": 0, "grid": {}, "gridPos": {"h": 21, "w": 24, "x": 0, "y": 21}, "hiddenSeries": false, "id": 16, "isNew": true, "legend": {"alignAsTable": true, "avg": true, "current": false, "max": true, "min": true, "rightSide": true, "show": true, "sort": "current", "sortDesc": true, "total": false, "values": true}, "lines": true, "linewidth": 1, "links": [], "nullPointMode": "connected", "options": {"alertThreshold": true}, "percentage": false, "pluginVersion": "8.5.2", "pointradius": 1, "points": true, "renderer": "flot", "seriesOverrides": [], "spaceLength": 10, "stack": false, "steppedLine": false, "targets": [{"alias": "", "datasource": {"type": "mssql", "uid": "55sV9KGMz"}, "format": "time_series", "rawSql": "SELECT DATEADD(hh, -9, CollectDTM) as time, ServerHost, Rsrc_Val\r\n  FROM [dbo].[TB_Rds_Rsrc_L] 
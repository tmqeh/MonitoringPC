etricName": "", "metricQueryType": 0, "namespace": "", "rawSql": "SELECT z.PART_CL_CD [\ud30c\ud2b8\uba85], z.hostName [\ud638\uc2a4\ud2b8\uba85], z.serviceName [\uc11c\ube44\uc2a4\uba85]\r\n     , MAX([CPU \uc0c1\ud0dc]          ) AS [CPU \uc0c1\ud0dc]\r\n     , MAX([Memory \uc0c1\ud0dc]       ) AS [Memory \uc0c1\ud0dc]\r\n     , MAX([Disk \uc0c1\ud0dc]         ) AS [Disk \uc0c1\ud0dc]\r\n     , MAX([Cache Battery \uc0c1\ud0dc]) AS [Cache Battery \uc0c1\ud0dc]\r\n     , MAX([Controller \uc0c1\ud0dc]   ) AS [Controller \uc0c1\ud0dc]\r\n     , MAX([Fan \uc0c1\ud0dc]          ) AS [Fan \uc0c1\ud0dc]\r\n     , MAX([Power Supply \uc0c1\ud0dc] ) AS [Power Supply \uc0c1\ud0dc]\r\n     , MAX([EventLog]          ) AS [EventLog]\r\n     , MIN(RGST_DTM) [\ub4f1\ub85d\uc77c\uc2dc]\r\n  FROM (\r\n        SELECT B.collectDT, A.PART_CL_CD, a.hostName, a.serviceName, b.RGST_DTM\r\n             , CASE WHEN B.statusName = 'CPU Status'        THEN CASE STATUS WHEN 'OK' THEN 0 WHEN 'NOK' THEN 1 ELSE 2 END END AS [CPU \uc0c1\ud0dc]\r\n             , CASE WHEN B.statusName = 'Memory Status'     THEN CASE STATUS WHEN 'OK' THEN 0 WHEN 'NOK' THEN 1 ELSE 2 END END AS [Memory \uc0c1\ud0dc]\r\n             , CASE WHEN B.statusName = 'Disk Status'       THEN CASE STATUS WHEN 'OK' THEN 0 WHEN 'NOK' THEN 1 ELSE 2 END END AS [Disk \uc0c1\ud0dc]\r\n             , CASE WHEN B.statusName = 'Cache Status'      THEN CASE STATUS WHEN 'OK' THEN 0 WHEN 'NOK' THEN 1 ELSE 2 END END AS [Cache Battery \uc0c1\ud0dc]\r\n             , CASE WHEN B.statusName = 'Controller Status' THEN CASE STATUS WHEN 'OK' THEN 0 WHEN 'NOK' THEN 1 ELSE 2 END END AS [Controller \uc0c1\ud0dc]\r\n             , CASE WHEN B.statusName = 'Fan Status'        THEN CASE STATUS WHEN 'OK' THEN 0 WHEN 'NOK' THEN 1 ELSE 2 END END AS [Fan \uc0c1\ud0dc]\r\n             , CASE WHEN B.statusName = 'PS Status'         THEN CASE STATUS WHEN 'OK' THEN 0 WHEN 'NOK' THEN 1 ELSE 2 END END AS [Power Supply \uc0c1\ud0dc]\r\n             , CASE WHEN B.statusName = 'Event Log'         THEN CASE STATUS WHEN 'OK' THEN 0 WHEN 'NOK' THEN 1 ELSE 2 END END AS [EventLog]\r\n             , ROW_NUMBER() OVER (PARTITION BY a.hostname, b.statusName order by b.rgst_dtm desc) rnk\r\n          FROM TB_SVR_COMM_INFO_M (NOLOCK) A\r\n          LEFT OUTER JOIN [TB_Svr_Stat_Chk_L]  (NOLOCK) B\r\n            ON A.hostName = B.hostName\r\n           AND B.collectDT = CONVERT(VARCHAR, GETDATE(), 112) \r\n         WHERE 1=1\r\n           AND A.STAT_YN = 'Y'\r\n           AND A.PART_CL_CD IN ($PartNm)\r\n  ) z\r\n  WHERE RNK = 1\r\nGROUP BY z.PART_CL_CD, z.hostName, z.serviceName", "refId": "A", "region": "default", "statistic": "Average"}], "title": "daily check server status", "transform": "table", "type": "table-old"}, {"columns": [], "datasource": {"type": "mssql", "uid": "55sV9KGMz"}, "fontSize": "90%", "gridPos": {"h": 12, "w": 24, "x": 0, "y": 25}, "id": 8, "showHeader": true, "sort": {"col": 4, "desc": true}, "styles": [{"$$hashKey": "object:262", "alias": "Time", "align": "auto", "dateFormat": "YYYY-MM-DD HH:mm:ss", "pattern": "Time", "type": "date"}, {"$$hashKey": "object:265", "alias": "", "align": "right", "colorMode": "value", "colors": ["rgba(50, 172, 45, 0.97)", "rgba(50, 172, 45, 0.97)", "rgba(245, 54, 54, 0.9)"], "dateFormat": "YYYY-MM-DD HH:mm:ss", "decimals": 2, "mappingType": 1, "pattern": "/Status/", "thresholds": ["0", "1"], "type": "string", "unit": "short", "valueMaps": [{"$$hashKey": "object:1102", "text": "\uc815\uc0c1", "value": "0"}, {"$$hashKey": "object:1104", "text": "\ube44\uc815\uc0c1", "value": "1"}, {"$$hashKey": "object:1367", "text": "\ube44\uc815\uc0c1", "value": "2"}]}, {"$$hashKey": "object:268", "alias": "", "align": "", "colorMode": "value", "colors": ["rgba(50, 172, 45, 0.97)", "#73BF69", "#FADE2A"], "dateFormat": "YYYY-MM-DD HH:mm:ss", "mappingType": 1, "pattern": "State", "thresholds": ["0", "1"], "type": "string", "unit": "none", "valueMaps": [{"$$hashKey": "object:1160", "text": "\uc644\ub8c
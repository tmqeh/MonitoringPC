{"id": 9, "uid": "e3b43a2d-b3a7-43cb-9b6a-a0a9c8813dae", "orgID": 1, "folderUID": "ujrKOKtVk", "ruleGroup": "DBA \ubaa8\ub2c8\ud130\ub9c1 \uadf8\ub8f9", "title": "\ub77d \uce74\uc6b4\ud2b8 (\uc804\uccb4)", "condition": "\uc784\uacc4\uce58", "data": [{"refId": "\ub77d\uce74\uc6b4\ud2b8", "queryType": "", "relativeTimeRange": {"from": 300, "to": 0}, "datasourceUid": "IJkAscnVz", "model": {"dataset": "MonitoringDB", "datasource": {"type": "mssql", "uid": "IJkAscnVz"}, "editorMode": "code", "format": "time_series", "intervalMs": 60000, "maxDataPoints": 43200, "rawQuery": true, "rawSql": "SELECT ISNULL(w.CollectDate, GETDATE()) as time, substring(i.ServerName, 2, charindex(']', i.ServerName)-2) as PartName, i.ServerName, SUM(case when w.Blocking_session_id > 0 then 1 else 0 end) CNT \r\nFROM META2_M_InstanceInfo i (nolock)\r\nLEFT OUTER JOIN TBL2_M_WhoIsActive w (nolock)\r\nON w.instanceID = i.instanceID \r\nAND w.CollectDate BETWEEN DATEADD(HOUR, 9, $__timeFrom()) AND DATEADD(HOUR, 9, $__timeTo())\r\n-- AND w.Blocking_session_id > 0\r\nWHERE 1=1\r\nAND i.ServerName not like '%\uc810%'\r\nand i.ServerName not like '%\ubab0%'\r\nand i.ServerName not like '%\uc544\uc6b8\ub81b%'\r\nand i.UseYN = 'Y'\r\n-- DRM\ub9cc \uc608\uc678 \uc2dc\uac04 \uc801\uc6a9\ud558\uc5ec \ubaa8\ub2c8\ud130\ub9c1\r\nAND i.instanceID <> 51\r\n-- SCOM \ubaa8\ub2c8\ud130\ub9c1 \ub300\uc0c1 \uc81c\uc678\r\nAND i.instanceID <> 11\r\nGROUP BY w.CollectDate, substring(i.ServerName, 2, charindex(']', i.ServerName)-2), i.ServerName\r\norder by time", "refId": "\ub77d\uce74\uc6b4\ud2b8", "sql": {"columns": [{"parameters": [], "type": "function"}], "groupBy": [{"property": {"type": "string"}, "type": "groupBy"}], "limit": 50}}}, {"refId": "\ud604\uc7ac\uac12", "queryType": "", "relativeTimeRange": {"from": 300, "to": 0}, "datasourceUid": "__expr__", "model": {"conditions": [{"evaluator": {"params": [], "type": "gt"}, "operator": {"type": "and"}, "query": {"params": ["B"]}, "reducer": {"params": [], "type": "last"}, "type": "query"}], "datasource": {"type": "__expr__", "uid": "__expr__"}, "expression": "\ub77d\uce74\uc6b4\ud2b8", "intervalMs": 1000, "maxDataPoints": 43200, "reducer": "last", "refId": "\ud604\uc7ac\uac12", "settings": {"mode": "dropNN"}, "type": "reduce"}}, {"refId": "\uc784\uacc4\uce58", "queryType": "", "relativeTimeRange": {"from": 300, "to": 0}, "datasourceUid": "__expr__", "model": {"conditions": [{"evaluator": {"params": [5], "type": "gt"}, "operator": {"type": "and"}, "query": {"params": ["C"]}, "reducer": {"params": [], "type": "last"}, "type": "query"}], "datasource": {"type": "__expr__", "uid": "__expr__"}, "expression": "\ud604\uc7ac\uac12", "intervalMs": 1000, "maxDataPoints": 43200, "refId": "\uc784\uacc4\uce58", "type": "threshold"}}], "updated": "2024-09-02T17:58:15+09:00", "noDataState": "OK", "execErrState": "Alerting", "for": "1m", "annotations": {"__dashboardUid__": "de4630ad-f09c-4cf6-9671-7f99525876e1", "__panelId__": "12", "summary": "MS-SQL Blocking \ubaa8\ub2c8\ud130\ub9c1"}, "labels": {"DBMS": "MS-SQL", "\ub9ac\uc18c\uc2a4": "Blocking", "\ucc44\ub110": "Jandi"}, "isPaused": false}